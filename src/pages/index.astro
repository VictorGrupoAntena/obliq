---
import BaseLayout from '@/layouts/BaseLayout.astro';
import HeroSection from '@/components/sections/HeroSection.astro';
import SectionHeader from '@/components/sections/SectionHeader.astro';
import CTASection from '@/components/sections/CTASection.astro';
import Marquee from '@/components/organisms/Marquee.astro';
import CustomCursor from '@/components/organisms/CustomCursor.astro';
import Button from '@/components/atoms/Button.astro';
import Paragraph from '@/components/atoms/Paragraph.astro';
import { t, localizedUrl } from '@/lib/i18n';
import { getServicesAsync } from '@/data/services';
import { getFeaturedProjectsAsync } from '@/data/portfolio';
import { getClientNamesAsync } from '@/data/clients';

const locale = 'es';
const i18n = t(locale);

const services = await getServicesAsync();
const portfolioProjects = await getFeaturedProjectsAsync();
const clientNames = await getClientNamesAsync();
---

<BaseLayout
  title={i18n.HOME.TITLE}
  description={i18n.GLOBAL.DESCRIPTION}
  locale={locale}
>
  <!-- 1. Hero -->
  <HeroSection
    tag={i18n.HOME.HERO_TAG}
    title={i18n.HOME.HERO_TITLE}
    subtitle={i18n.HOME.HERO_SUBTITLE}
    backgroundImage="/hero.jpg"
  >
    <div class="flex gap-4 flex-wrap">
      <Button variant="primary" href={localizedUrl('/servicios/', locale)}>
        {i18n.HOME.HERO_CTA_PRIMARY}
      </Button>
      <Button variant="outline" href={localizedUrl('/contacto/', locale)}>
        {i18n.HOME.HERO_CTA_SECONDARY}
      </Button>
    </div>
  </HeroSection>

  <!-- 2. Services Grid -->
  <section class="bg-black py-spacing-section px-4 md:px-spacing-section">
    <SectionHeader tag={i18n.HOME.SERVICES_TAG} title={i18n.HOME.SERVICES_TITLE} />
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      {services.map((svc) => {
        const data = i18n.SERVICES[svc.key as keyof typeof i18n.SERVICES];
        return (
          <a
            href={localizedUrl('/servicios/' + svc.slug.es + '/', locale)}
            class="service-card bg-surface-dark p-6 flex flex-col justify-between min-h-[151px] group transition-colors hover:bg-border"
          >
            <div>
              <h3 class="text-[16px] font-bold mb-2">{data.NAME}</h3>
              <p class="text-[13px] font-light text-secondary line-clamp-2">{data.DESCRIPTION}</p>
            </div>
            <span class="inline-flex items-center gap-2 text-[11px] font-semibold uppercase tracking-[3px] mt-4 opacity-0 group-hover:opacity-100 transition-opacity">
              VER SERVICIO
              <svg width="12" height="12" viewBox="0 0 18 18" fill="none" class="transition-transform group-hover:translate-x-1" aria-hidden="true">
                <path d="M12.3461 0.839999L17.9061 9.04L12.3461 17.32H8.86609L14.1061 9.04L8.86609 0.839999H12.3461ZM14.9061 7.6V10.52H0.426094V7.6H14.9061Z" fill="currentColor" />
              </svg>
            </span>
          </a>
        );
      })}
    </div>
  </section>

  <!-- 3. Marquee — Work -->
  <Marquee items={i18n.HOME.MARQUEE_WORK} size="large" />

  <!-- 4. Portfolio -->
  <section class="bg-black py-spacing-section px-4 md:px-spacing-section">
    <SectionHeader tag={i18n.HOME.PORTFOLIO_TAG} title={i18n.HOME.PORTFOLIO_TITLE} />
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-10">
      {portfolioProjects.map((project) => (
        <a href={localizedUrl('/portfolio/', locale)} class="portfolio-card custom-cursor-target relative overflow-hidden group aspect-[4/3]">
          <img
            src={project.image}
            alt={project.title.es}
            class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent" />
          <div class="absolute bottom-0 left-0 right-0 p-6">
            <p class="text-[12px] font-medium uppercase tracking-[2px] text-muted mb-2">{project.category}</p>
            <h3 class="text-[20px] font-bold italic">{project.title.es}</h3>
          </div>
        </a>
      ))}
    </div>
    <div class="text-center">
      <Button variant="ghost" href={localizedUrl('/portfolio/', locale)}>
        {i18n.HOME.PORTFOLIO_CTA}
      </Button>
    </div>
  </section>

  <!-- 5. Marquee — Brands -->
  <Marquee items={clientNames} size="small" />

  <!-- 6. About Teaser -->
  <section class="bg-surface-dark py-spacing-section px-4 md:px-spacing-section">
    <SectionHeader tag={i18n.HOME.ABOUT_TAG} title={i18n.HOME.ABOUT_TITLE} />
    <Paragraph class="text-secondary max-w-3xl mb-10">
      {i18n.HOME.ABOUT_TEXT}
    </Paragraph>
    <Button variant="outline" href={localizedUrl('/nosotros/', locale)}>
      {i18n.HOME.ABOUT_CTA}
    </Button>
  </section>

  <CustomCursor />

  <!-- 7. CTA -->
  <CTASection title={i18n.HOME.CTA_TITLE}>
    <Button variant="primary" href={localizedUrl('/contacto/', locale)}>
      {i18n.HOME.CTA_BUTTON}
    </Button>
  </CTASection>
</BaseLayout>

<script>
  import { gsap, ScrollTrigger } from '@/lib/gsap';

  function initHomeAnimations() {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    // Service cards fade in
    const serviceCards = document.querySelectorAll('.service-card');
    if (serviceCards.length) {
      gsap.from(serviceCards, {
        opacity: 0,
        y: 30,
        duration: 0.4,
        ease: 'power2.out',
        stagger: 0.08,
        scrollTrigger: {
          trigger: serviceCards[0],
          start: 'top 85%',
          toggleActions: 'play none none reverse',
        },
      });
    }

    // Portfolio cards fade in
    const portfolioCards = document.querySelectorAll('.portfolio-card');
    if (portfolioCards.length) {
      gsap.from(portfolioCards, {
        opacity: 0,
        y: 30,
        duration: 0.4,
        ease: 'power2.out',
        stagger: 0.1,
        scrollTrigger: {
          trigger: portfolioCards[0],
          start: 'top 85%',
          toggleActions: 'play none none reverse',
        },
      });
    }
  }

  initHomeAnimations();
  document.addEventListener('astro:after-swap', initHomeAnimations);
</script>
