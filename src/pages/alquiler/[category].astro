---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SectionHeader from '@/components/sections/SectionHeader.astro';
import CTASection from '@/components/sections/CTASection.astro';
import ProductCard from '@/components/cards/ProductCard.astro';
import Breadcrumbs from '@/components/organisms/Breadcrumbs.astro';
import Heading from '@/components/atoms/Heading.astro';
import Paragraph from '@/components/atoms/Paragraph.astro';
import Button from '@/components/atoms/Button.astro';
import { t, localizedUrl } from '@/lib/i18n';
import { breadcrumbSchema } from '@/lib/schema';
import { getCategoriesAsync } from '@/data/rental';

export async function getStaticPaths() {
  const categories = await getCategoriesAsync();
  return categories.map((cat) => ({
    params: { category: cat.slug.es },
    props: { category: cat },
  }));
}

const locale = 'es';
const i18n = t(locale);
const r = i18n.RENTAL;
const { category } = Astro.props;
const categorySlug = category.slug.es;

const breadcrumbItems = [
  { label: i18n.BREADCRUMBS.HOME, href: '/' },
  { label: i18n.NAV.RENTAL, href: localizedUrl('/alquiler/', locale) },
  { label: category.name.es },
];
---

<BaseLayout
  title={category.name.es + ' — ' + r.TITLE}
  description={category.description.es}
  locale={locale}
  pageColor="white"
  schema={breadcrumbSchema(breadcrumbItems)}
>
  <!-- Breadcrumbs -->
  <Breadcrumbs items={breadcrumbItems} />

  <!-- Hero -->
  <section class="bg-surface-dark py-section px-4 md:px-section">
    <Heading level={1} class="text-white mb-4">{category.name.es.toUpperCase()}</Heading>
    <Paragraph class="text-secondary max-w-2xl">{category.description.es}</Paragraph>
  </section>

  <!-- Products Grid -->
  <section class="bg-surface-light py-section px-4 md:px-section">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {category.products.map((product) => (
        <ProductCard
          name={product.name}
          price={product.price}
          image={product.image}
          href={localizedUrl('/alquiler/' + categorySlug + '/' + product.slug + '/', locale)}
          slug={product.slug}
          categorySlug={categorySlug}
          specs={product.specs.es}
          ctaText={r.ADD_TO_QUOTE}
          addedText={r.CART_ADDED}
          perDay={r.PER_DAY}
          vat={r.VAT}
          theme="light"
        />
      ))}
    </div>
  </section>

  <!-- CTA -->
  <CTASection title={r.CTA_TITLE} background="white">
    <Button variant="dark" href={localizedUrl('/contacto/', locale)}>
      {r.CTA_BUTTON}
    </Button>
  </CTASection>
</BaseLayout>

<script>
  import { initScrollFadeInAll } from '@/lib/gsap';

  function initCategoryAnimations() {
    initScrollFadeInAll([
      ['.grid > *', '.bg-surface-light', { stagger: 0.08 }],
    ]);
  }

  initCategoryAnimations();
  document.addEventListener('astro:after-swap', initCategoryAnimations);
</script>
