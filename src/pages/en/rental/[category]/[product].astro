---
import BaseLayout from '@/layouts/BaseLayout.astro';
import CTASection from '@/components/sections/CTASection.astro';
import SectionHeader from '@/components/sections/SectionHeader.astro';
import ProductCompactCard from '@/components/cards/ProductCompactCard.astro';
import Breadcrumbs from '@/components/organisms/Breadcrumbs.astro';
import Heading from '@/components/atoms/Heading.astro';
import Paragraph from '@/components/atoms/Paragraph.astro';
import Button from '@/components/atoms/Button.astro';
import { t, localizedUrl } from '@/lib/i18n';
import { productSchema, breadcrumbSchema } from '@/lib/schema';
import { getCategoriesAsync, discountTiers, getDiscountedPrice } from '@/data/rental';

export async function getStaticPaths() {
  const categories = await getCategoriesAsync();
  return categories.flatMap((cat) =>
    cat.products.map((product) => ({
      params: { category: cat.slug.en, product: product.slug },
      props: { category: cat, product },
    }))
  );
}

const locale = 'en';
const i18n = t(locale);
const r = i18n.RENTAL;
const { category, product } = Astro.props;
const categorySlug = category.slug.en;
const relatedProducts = category.products.filter((p) => p.slug !== product.slug).slice(0, 3);

const breadcrumbItems = [
  { label: i18n.BREADCRUMBS.HOME, href: '/en/' },
  { label: i18n.NAV.RENTAL, href: localizedUrl('/rental/', locale) },
  { label: category.name.en, href: localizedUrl('/rental/' + categorySlug + '/', locale) },
  { label: product.name },
];

const schema = productSchema(product.name, String(product.price), product.image);
---

<BaseLayout
  title={product.name + ' — ' + r.TITLE}
  description={product.description.en}
  locale={locale}
  pageColor="white"
  schema={schema}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema(breadcrumbItems))} />
  </Fragment>

  <Breadcrumbs items={breadcrumbItems} />

  <section class="bg-surface-light py-section px-4 md:px-section">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-16">
      <div class="bg-white p-8 flex items-center justify-center aspect-square">
        <img src={product.image} alt={product.name} class="max-w-full max-h-full object-contain" />
      </div>
      <div>
        <Heading level={1} italic={false} class="text-black mb-4">{product.name}</Heading>
        <p class="mb-6">
          <span class="text-[32px] font-extrabold text-black">{product.price}€</span>
          <span class="text-[16px] font-light text-muted">{r.PER_DAY}</span>
          <span class="text-[13px] font-light text-muted ml-1">{r.VAT}</span>
        </p>
        <Paragraph class="text-muted mb-8">{product.description.en}</Paragraph>
        <h2 class="text-[14px] font-semibold uppercase tracking-[2px] text-black mb-4">{r.SPECS}</h2>
        <div class="space-y-0 mb-8">
          {product.specs.en.map((spec, i) => (
            <div class:list={['flex items-start gap-3 py-3 text-[14px]', i > 0 && 'border-t border-border-light']}>
              <span class="text-muted font-light">{spec}</span>
            </div>
          ))}
        </div>
        <!-- Multi-day discounts -->
        <h2 class="text-[14px] font-semibold uppercase tracking-[2px] text-black mb-4">{r.DISCOUNTS_TITLE}</h2>
        <div class="mb-8 border border-border-light">
          <div class="grid grid-cols-4 text-[11px] font-semibold uppercase tracking-[2px] text-muted bg-surface-light px-4 py-3">
            <span>{r.DISCOUNTS_DURATION}</span>
            <span>{r.DISCOUNTS_PRICE_DAY}</span>
            <span>{r.DISCOUNTS_TOTAL}</span>
            <span>{r.DISCOUNTS_SAVE}</span>
          </div>
          {discountTiers.map((tier) => {
            const dailyDiscounted = tier.discount > 0 ? Math.round(product.price * (1 - tier.discount / 100)) : product.price;
            const total = getDiscountedPrice(product.price, tier.days);
            return (
              <div class:list={['grid grid-cols-4 px-4 py-3 text-[14px] border-t border-border-light', tier.discount > 0 && 'bg-surface-light/50']}>
                <span class="font-medium text-black">{tier.label.en}</span>
                <span class="text-black">{dailyDiscounted}€</span>
                <span class="font-bold text-black">{total}€</span>
                <span class:list={[tier.discount > 0 ? 'text-black font-semibold' : 'text-muted']}>
                  {tier.discount > 0 ? '-' + tier.discount + '%' : '—'}
                </span>
              </div>
            );
          })}
        </div>

        <button
          type="button"
          class="cart-add-btn w-full md:w-auto inline-flex items-center justify-center gap-3 uppercase font-semibold tracking-[3px] h-[52px] px-8 text-[11px] bg-black text-white hover:bg-surface-dark transition-all cursor-pointer"
          data-product-slug={product.slug}
          data-product-name={product.name}
          data-product-price={product.price}
          data-product-image={product.image}
          data-category-slug={categorySlug}
          data-cta-text={r.ADD_TO_QUOTE}
          data-added-text={r.CART_ADDED}
          aria-label={r.ADD_TO_QUOTE + ' — ' + product.name}
        >
          <span class="btn-label">{r.ADD_TO_QUOTE}</span>
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none" class="transition-transform" aria-hidden="true">
            <path d="M12.3461 0.839999L17.9061 9.04L12.3461 17.32H8.86609L14.1061 9.04L8.86609 0.839999H12.3461ZM14.9061 7.6V10.52H0.426094V7.6H14.9061Z" fill="currentColor" />
          </svg>
        </button>
      </div>
    </div>
  </section>

  {relatedProducts.length > 0 && (
    <section class="bg-surface-light pb-section px-4 md:px-section">
      <SectionHeader tag={r.RELATED_TAG} title={r.RELATED_TITLE} theme="light" />
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        {relatedProducts.map((rp) => (
          <ProductCompactCard
            name={rp.name}
            price={rp.price}
            image={rp.image}
            href={localizedUrl('/rental/' + categorySlug + '/' + rp.slug + '/', locale)}
            perDay={r.PER_DAY}
          />
        ))}
      </div>
    </section>
  )}

  <CTASection title={r.CTA_TITLE} background="white">
    <Button variant="dark" href={localizedUrl('/contact/', locale)}>{r.CTA_BUTTON}</Button>
  </CTASection>
</BaseLayout>

<script>
  import { initScrollFadeIn } from '@/lib/gsap';
  import { toggleCart, isInCart } from '@/lib/cart-store';
  import type { CartItem } from '@/lib/cart-store';

  function initProductPage() {
    initScrollFadeIn('.grid.grid-cols-1.md\\:grid-cols-2 > *', undefined, { stagger: 0.2, y: 30 });

    document.querySelectorAll<HTMLButtonElement>('.cart-add-btn').forEach((btn) => {
      const slug = btn.dataset.productSlug!;
      const label = btn.querySelector('.btn-label')!;
      const ctaText = btn.dataset.ctaText!;
      const addedText = btn.dataset.addedText!;

      if (isInCart(slug)) {
        label.textContent = addedText;
        btn.classList.add('is-in-cart');
      }

      btn.addEventListener('click', (e) => {
        e.preventDefault();
        const item: CartItem = {
          productSlug: slug,
          productName: btn.dataset.productName!,
          categorySlug: btn.dataset.categorySlug!,
          price: parseFloat(btn.dataset.productPrice!),
          image: btn.dataset.productImage!,
          days: 1,
        };
        const added = toggleCart(item);
        label.textContent = added ? addedText : ctaText;
        btn.classList.toggle('is-in-cart', added);
      });
    });
  }

  initProductPage();
  document.addEventListener('astro:after-swap', initProductPage);
</script>
