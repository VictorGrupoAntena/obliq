---
interface Props {
  name: string;
  description: string;
  count: number;
  href: string;
  ctaText: string;
  countLabel: string;
}

const { name, description, count, href, ctaText, countLabel } = Astro.props;
---

<a href={href} class="group bg-white p-6 border border-border-light transition-colors hover:bg-surface-light">
  <h3 class="text-[18px] font-bold text-black mb-2">{name}</h3>
  <p class="text-[14px] font-light text-muted mb-3 line-clamp-2">{description}</p>
  <p class="text-[12px] font-medium text-muted mb-4">{count} {countLabel}</p>
  <span class="inline-flex items-center gap-2 text-[11px] font-semibold uppercase tracking-[3px] text-black opacity-0 group-hover:opacity-100 transition-opacity">
    {ctaText}
    <svg width="12" height="12" viewBox="0 0 18 18" fill="none" class="transition-transform group-hover:translate-x-1" aria-hidden="true">
      <path d="M12.3461 0.839999L17.9061 9.04L12.3461 17.32H8.86609L14.1061 9.04L8.86609 0.839999H12.3461ZM14.9061 7.6V10.52H0.426094V7.6H14.9061Z" fill="currentColor" />
    </svg>
  </span>
</a>
