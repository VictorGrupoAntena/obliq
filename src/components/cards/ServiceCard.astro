---
interface Props {
  title: string;
  description: string;
  image?: string;
  href: string;
  ctaText?: string;
}

const { title, description, image, href, ctaText = 'VER SERVICIO' } = Astro.props;
---

{image ? (
  <a href={href} class="group block bg-surface-dark overflow-hidden">
    <div class="aspect-video overflow-hidden">
      <img
        src={image}
        alt={title}
        class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
        loading="lazy"
      />
    </div>
    <div class="p-6">
      <h3 class="text-[18px] font-bold mb-2">{title}</h3>
      <p class="text-[14px] font-light text-secondary mb-4 line-clamp-2">{description}</p>
      <span class="inline-flex items-center gap-2 text-[11px] font-semibold uppercase tracking-[3px] text-white opacity-0 group-hover:opacity-100 transition-opacity">
        {ctaText}
        <svg width="12" height="12" viewBox="0 0 18 18" fill="none" class="transition-transform group-hover:translate-x-1" aria-hidden="true">
          <path d="M12.3461 0.839999L17.9061 9.04L12.3461 17.32H8.86609L14.1061 9.04L8.86609 0.839999H12.3461ZM14.9061 7.6V10.52H0.426094V7.6H14.9061Z" fill="currentColor" />
        </svg>
      </span>
    </div>
  </a>
) : (
  <a href={href} class="group bg-surface-dark p-6 flex flex-col justify-between min-h-[151px] transition-colors hover:bg-border">
    <div>
      <h3 class="text-[16px] font-bold mb-2">{title}</h3>
      <p class="text-[13px] font-light text-secondary line-clamp-2">{description}</p>
    </div>
    <span class="inline-flex items-center gap-2 text-[11px] font-semibold uppercase tracking-[3px] mt-4 opacity-0 group-hover:opacity-100 transition-opacity">
      {ctaText}
      <svg width="12" height="12" viewBox="0 0 18 18" fill="none" class="transition-transform group-hover:translate-x-1" aria-hidden="true">
        <path d="M12.3461 0.839999L17.9061 9.04L12.3461 17.32H8.86609L14.1061 9.04L8.86609 0.839999H12.3461ZM14.9061 7.6V10.52H0.426094V7.6H14.9061Z" fill="currentColor" />
      </svg>
    </span>
  </a>
)}
