---
interface Props {
  name: string;
  price: number;
  image: string;
  href: string;
  perDay: string;
}

const { name, price, image, href, perDay } = Astro.props;
---

<a href={href} class="group flex items-center gap-4 p-3 bg-white border border-border-light hover:bg-surface-light transition-colors">
  <div class="w-16 h-16 shrink-0 bg-surface-light flex items-center justify-center p-1">
    <img src={image} alt={name} class="max-w-full max-h-full object-contain" loading="lazy" />
  </div>
  <div class="flex-1 min-w-0">
    <h4 class="text-[16px] font-bold text-black truncate">{name}</h4>
    <p>
      <span class="text-[13px] font-semibold text-black">{price}€</span>
      <span class="text-[12px] font-light text-muted">{perDay}</span>
    </p>
  </div>
</a>
