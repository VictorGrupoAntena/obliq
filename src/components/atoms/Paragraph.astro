---
interface Props {
  size?: 'body' | 'small' | 'caption';
  class?: string;
}

const { size = 'body', class: className } = Astro.props;

const sizeClasses = {
  body: 'text-[16px] md:text-[18px] font-light leading-relaxed',
  small: 'text-[14px] font-normal leading-normal',
  caption: 'text-[12px] font-medium tracking-[3px] uppercase',
};
---

<p class:list={[sizeClasses[size], className]}>
  <slot />
</p>
